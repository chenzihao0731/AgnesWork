{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgnesWork",
  "version": "0.1.0",
  "identifier": "com.agnes.work",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgnesWork",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "AgnesWork multi-modal AI agent desktop app",
    "longDescription": "A desktop AI assistant powered by Agnes AI models. Supports chat, image generation and video generation through a multi-agent tool-calling loop."
  },
  "plugins": {}
}
